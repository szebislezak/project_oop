            })
            if r3 and r3.retcode == mt5.TRADE_RETCODE_DONE:
                opened.append(("HOLD", r3.order, r3.price, None))
                _th.Thread(target=_at_position_monitor,
                    args=(r3.order, side, r3.price, sl, tp1, None, None, sig.be_after_tp1, tp1_hit_event),
                    daemon=True).start()
            else:
                errors.append(f"Poz3(HOLD): {r3.comment if r3 else 'None'}")

        # --- Értesítő admin-nak ---
        be_s = "\n🔁 TP1 után: BE" if sig.be_after_tp1 else ""
        tp2_s = int(tp2) if tp2 else "–"
        msg_lines = [
            f"✅ {len(opened)}/{admin_max} pozíció nyitva: {side} @ {price:.2f}",
