class Engine:
    def __init__(self, persist_state: bool = True):
        self.persist_state = persist_state
        self.last_signal_time: Optional[datetime] = None
        self.last_bar_index: int = -999
        self.zone_last_fired: Dict[str, datetime] = {}  # zone_id -> last fired time
        self.last_seen_trigger_bar_time: Optional[pd.Timestamp] = None
        self.last_status_log_time: Optional[datetime] = None
        self.last_no_signal_reason: str = "startup"
        self.last_scan_reason: str = "startup"
        self.last_signal_side: Optional[str] = None
        self.signal_signature_last_fired: Dict[str, datetime] = {}
        self.last_blocked_signature: Optional[str] = None
        self.last_blocked_log_time: Optional[datetime] = None
        self.last_blocked_trigger_bar_time: Optional[datetime] = None
        self._last_chop_reject: Optional[str] = None
        self.last_signal_zone_low: Optional[int] = None
        self.last_signal_zone_high: Optional[int] = None
        if self.persist_state:
            self._load_state()

    def _bar_ratios(self, bar: pd.Series) -> Dict[str, float]:
        o = float(bar["open"])
        h = float(bar["high"])
        l = float(bar["low"])
        c = float(bar["close"])
        rng = max(0.5, h - l)
        return {
            "open": o,
            "high": h,
            "low": l,
            "close": c,
            "body_ratio": abs(c - o) / rng,
            "upper_wick_ratio": max(0.0, h - max(o, c)) / rng,
            "lower_wick_ratio": max(0.0, min(o, c) - l) / rng,
        }

    def _zone_mid(self, zone_low: int, zone_high: int) -> int:
        return round_int((float(zone_low) + float(zone_high)) / 2.0)

    def _entry_distance_metrics(self, side: str, entry_ref: int, zone_low: int, zone_high: int) -> Dict[str, float]:
        zone_mid = self._zone_mid(zone_low, zone_high)
        edge_distance = max(0.0, float(entry_ref - zone_high)) if side == "BUY" else max(0.0, float(zone_low - entry_ref))
        mid_distance = abs(float(entry_ref) - float(zone_mid))
        return {
            "zone_mid": float(zone_mid),
            "entry_vs_zone_edge_distance": edge_distance,
            "entry_vs_zone_mid_distance": mid_distance,
        }

    def _candidate_score(self, payload: Dict[str, Any]) -> float:
        try:
            return float(payload.get("strength", 0.0))
        except Exception:
            return 0.0

    def _update_best_blocked(self, current: Optional[Dict[str, Any]], candidate: Dict[str, Any]) -> Dict[str, Any]:
        if current is None:
            return candidate
        return candidate if self._candidate_score(candidate) >= self._candidate_score(current) else current

    def _json_safe(self, value: Any) -> Any:
        if isinstance(value, datetime):
            dt = value if value.tzinfo is not None else value.replace(tzinfo=timezone.utc)
            return dt.astimezone(timezone.utc).isoformat()
        if isinstance(value, (np.floating, float)):
            return round(float(value), 6)
        if isinstance(value, (np.integer, int)):
            return int(value)
        if isinstance(value, bool):
            return bool(value)
        return value

    def _emit_structured_log(self, prefix: str, payload: Dict[str, Any], jsonl_file: Optional[str] = None) -> None:
        ordered = {k: self._json_safe(v) for k, v in payload.items()}
        line = " ".join(f"{k}={ordered[k]}" for k in ordered)
        print(f"[{prefix}] {line}")
        if jsonl_file:
            try:
                with open(jsonl_file, "a", encoding="utf-8") as fh:
                    fh.write(json.dumps(ordered, ensure_ascii=False) + "\n")
            except Exception as exc:
                print(f"[SIGNAL_LOG_ERROR] file={jsonl_file} error={exc}")

    def _emit_signal_found(self, sig: Signal) -> None:
        zone_mid = self._zone_mid(sig.zone_low, sig.zone_high)
        payload = {
            "timestamp": now_utc(),
            "regime": sig.regime,
            "bias": sig.bias,
            "trigger_type": sig.trigger_type,
            "candidate_source": sig.candidate_source,
            "side": sig.side,
            "strength": sig.strength,
            "entry": sig.entry,
            "order_type": sig.order_type,
            "zone_low": sig.zone_low,
            "zone_high": sig.zone_high,
            "zone_mid": zone_mid,
            "sl": sig.sl,
            "tp1": sig.tps[0] if len(sig.tps) > 0 else None,
            "tp2": sig.tps[1] if len(sig.tps) > 1 else None,
            "tp3": sig.tps[2] if len(sig.tps) > 2 else None,
            "trend_score": sig.trend_score,
