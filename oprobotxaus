def _generate_invite_code() -> str:
    import random
    import string
    chars = string.ascii_uppercase + string.digits
    while True:
        code = "".join(random.choices(chars, k=6))
        if code not in _invite_codes:
            return code

def _create_invite(note: str = "") -> str:
    """Új meghívó kód generálása."""
    with _invite_lock:
        code = _generate_invite_code()
        _invite_codes[code] = {
            "used": False,
            "used_by": None,
            "note": note,
            "created_at": datetime.now(timezone.utc).isoformat()
        }
        _save_invite_codes()
    return code

def _use_invite(code: str, chat_id: str) -> bool:
    """Meghívó kód felhasználása. True ha sikeres."""
    with _invite_lock:
        if code not in _invite_codes:
            return False
        inv = _invite_codes[code]
        if inv.get("used"):
            return False
        _invite_codes[code]["used"] = True
        _invite_codes[code]["used_by"] = chat_id
        _invite_codes[code]["used_at"] = datetime.now(timezone.utc).isoformat()
        _save_invite_codes()
    return True

def _is_invited(chat_id: str) -> bool:
    """Ellenőrzi hogy a chat_id már felhasznált-e meghívót."""
    with _invite_lock:
        for inv in _invite_codes.values():
            if inv.get("used_by") == chat_id:
                return True
    return False

