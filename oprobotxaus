                        execute_autotrade(sig)      # → MT5 ELŐSZÖR (saját számla)
                        if send_ok:
                            telegram_send(msg)      # → Telegram utána (ha signal send engedve)
                        else:
                            print("[TOGGLE] Telegram signal küldés tiltva (_signal_send_enabled=False)")
                        _write_signal_for_workers(sig)  # → worker.py-knek jelzés
                else:
                    now = now_utc()
                    should_log = (
                        engine.last_status_log_time is None
                        or (now - engine.last_status_log_time).total_seconds() >= max(60, STATUS_LOG_MINUTES * 60)
                    )
                    if should_log:
                        last_bar = engine.last_seen_trigger_bar_time
                        last_bar_s = last_bar.isoformat() if last_bar is not None else "n/a"
                        last_sig = engine.last_signal_time
                        last_sig_s = last_sig.isoformat() if last_sig is not None else "none_yet"
                        reason = engine.last_no_signal_reason
                        scan_reason = engine.last_scan_reason
                        chop_reject = getattr(engine, '_last_chop_reject', None)
                        chop_info = f" | chop_reject={chop_reject}" if chop_reject else ""
                        print(f"[LIVE] heartbeat: running, no new signal | reason={reason} | last_scan={scan_reason} | last_trigger_bar={last_bar_s} | last_signal={last_sig_s}{chop_info}")
                        engine.last_status_log_time = now
            finally:
                mt5_shutdown()
        except Exception as e:
            print(f"[LIVE] error: {e}")
        time.sleep(5)  # check frequently; trigger bar time prevents duplicates

