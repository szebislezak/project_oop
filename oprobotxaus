            })
            if r2 and r2.retcode == mt5.TRADE_RETCODE_DONE:
                opened.append(("TP2", r2.order, r2.price, tp2_target))
                _th.Thread(target=_at_position_monitor,
                    args=(r2.order, side, r2.price, sl, tp1, tp2, None, sig.be_after_tp1, tp1_hit_event),
                    daemon=True).start()
            else:
                errors.append(f"Poz2(TP2): {r2.comment if r2 else 'None'}")

        # --- Pozíció 3: HOLD (csak ha admin_max >= 3) ---
        if admin_max >= 3:
            r3 = mt5.order_send({
                "action": mt5.TRADE_ACTION_DEAL, "symbol": SYMBOL,
