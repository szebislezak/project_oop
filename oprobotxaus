def format_signal_message(sig: Signal) -> str:
    # ✅ Keep your clean style — max 3 TP: TP1, TP2, TP3 HOLD
    lines = []
    lines.append(f"{DISPLAY_SYMBOL}")
    lines.append("")
    lines.append(f"{fmt_side(sig.side)} {sig.zone_low} - {sig.zone_high}")
    lines.append("")
    lines.append(f"REGIME {sig.regime} | BIAS {sig.bias}")
    lines.append(f"TRIGGER {sig.trigger_type}")
    lines.append(f"STRENGTH {sig.strength:.2f}")
    lines.append("")
    lines.append(f"ENTRY {sig.order_type} {sig.entry}")
    lines.append("")
    lines.append(f"SL {sig.sl}")
    lines.append("")
    # Mindig csak 3 TP: TP1, TP2, TP3 HOLD
    real_tps = [t for t in sig.tps if t is not None]
    tp1_val = real_tps[0] if len(real_tps) > 0 else None
    tp2_val = real_tps[1] if len(real_tps) > 1 else None
    if tp1_val is not None:
        lines.append(f"TP1 {tp1_val}")
    else:
        lines.append("TP1 HOLD")
    if tp2_val is not None:
        lines.append(f"TP2 {tp2_val}")
    else:
        lines.append("TP2 HOLD")
    lines.append("TP3 HOLD")
    if sig.be_after_tp1:
        lines.append("")
        lines.append("TP1 után: BE")
    return "\n".join(lines)


