    def _generate_chop_mean_reversion_signal(self, symbol: str, recent: pd.DataFrame, df_tr: pd.DataFrame,
                                             lookback: int, now_utc_dt: datetime, market_state: MarketState,
                                             allow_live_tick: bool) -> Optional[Signal]:
        cooldown_block = 0
        reject_block = 0
        reentry_block = 0
        duplicate_block = 0
        stale_block = 0
        drift_block = 0
        strength_block = 0
        best_blocked: Optional[Dict[str, Any]] = None
        last_range_low: Optional[int] = None
        last_range_high: Optional[int] = None
        last_range_width = 0.0
        last_containment_ratio = 0.0
        last_range_atr_mult = 0.0
        max_age_bars = int(clamp(SIGNAL_MAX_AGE_BARS, 0, 200))
        max_age_seconds = max_age_bars * tf_to_seconds(TRIGGER_TF) if max_age_bars > 0 else None
        min_strength = max(MIN_SIGNAL_STRENGTH, CHOP_MIN_SIGNAL_STRENGTH)

        for i_bar in range(len(recent) - 1, -1, -1):
            bar_time = recent.index[i_bar].to_pydatetime()
            bar = recent.iloc[i_bar]
            bar_index = len(df_tr) - (lookback - i_bar)
            bar_metrics = self._bar_ratios(bar)
            bars_since_trigger = max(0, (len(df_tr) - 1) - bar_index)

            if max_age_seconds is not None:
                try:
                    bar_time_utc = bar_time.astimezone(timezone.utc) if bar_time.tzinfo is not None else bar_time.replace(tzinfo=timezone.utc)
                    if (now_utc_dt - bar_time_utc).total_seconds() > max_age_seconds:
                        stale_block += 1
                        best_blocked = self._update_best_blocked(best_blocked, self._make_blocked_payload(
                            market_state=market_state,
                            side="NA",
                            trigger_type="CHOP_MEAN_REVERSION",
                            reason="stale_block",
                            strength=0.0,
                            min_strength=min_strength,
                            entry_ref=None,
                            zone_low=last_range_low or 0,
                            zone_high=last_range_high or 0,
                            actual_drift_from_zone_edge=0.0,
                            max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                            bar_time=bar_time,
                            signal_bar_close=bar_metrics["close"],
                            entry_vs_zone_mid_distance=float(distance_metrics["entry_vs_zone_mid_distance"]),
                            bar_metrics=bar_metrics,
                            bars_since_trigger=bars_since_trigger,
                            zone_id="CHOP",
                        ))
                        continue
                except Exception:
                    pass

            trigger_range = self._compute_chop_range(df_tr, bar_index)
            if not trigger_range:
                reject_block += 1
                continue
            last_range_low = int(trigger_range["low"])
            last_range_high = int(trigger_range["high"])
            last_range_width = float(trigger_range["width"])
            last_containment_ratio = float(trigger_range.get("containment_ratio", 0.0))
            last_range_atr_mult = float(trigger_range.get("range_atr_mult", 0.0))

            trigger = self._chop_rejection_trigger(trigger_range, bar)
            if trigger is None:
                reject_block += 1
                continue
            side, strength = trigger

            if not self._cooldown_ok(bar_time, bar_index, side):
                cooldown_block += 1
                best_blocked = self._update_best_blocked(best_blocked, self._make_blocked_payload(
                    market_state=market_state,
                    side=side,
                    trigger_type="CHOP_MEAN_REVERSION",
                    reason="cooldown_block",
                    strength=strength,
                    min_strength=min_strength,
                    entry_ref=None,
                    zone_low=int(trigger_range["low"]),
                    zone_high=int(trigger_range["high"]),
                    actual_drift_from_zone_edge=0.0,
                    max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                    bar_time=bar_time,
                    signal_bar_close=bar_metrics["close"],
                    zone_id=f"CHOP:{side}:{trigger_range['low']}:{trigger_range['high']}",
                ))
                continue

            range_key = f"CHOP:{side}:{trigger_range['low']}:{trigger_range['high']}"
            if not self._zone_reentry_ok(range_key, bar_time):
                reentry_block += 1
                best_blocked = self._update_best_blocked(best_blocked, self._make_blocked_payload(
                    market_state=market_state,
                    side=side,
                    trigger_type="CHOP_MEAN_REVERSION",
                    reason="reentry_block",
                    strength=strength,
                    min_strength=min_strength,
                    entry_ref=None,
                    zone_low=int(trigger_range["low"]),
                    zone_high=int(trigger_range["high"]),
                    actual_drift_from_zone_edge=0.0,
                    max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                    bar_time=bar_time,
                    signal_bar_close=bar_metrics["close"],
                    zone_id=range_key,
                ))
                continue

            if strength < min_strength:
                strength_block += 1
                best_blocked = self._update_best_blocked(best_blocked, self._make_blocked_payload(
                    market_state=market_state,
                    side=side,
                    trigger_type="CHOP_MEAN_REVERSION",
                    reason="strength_block",
                    strength=strength,
                    min_strength=min_strength,
                    entry_ref=None,
                    zone_low=int(trigger_range["low"]),
                    zone_high=int(trigger_range["high"]),
                    actual_drift_from_zone_edge=0.0,
                    max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                    bar_time=bar_time,
                    signal_bar_close=bar_metrics["close"],
                    zone_id=range_key,
                ))
                continue

            entry_ref = self._pick_market_entry(symbol, side, float(bar["close"]), allow_live_tick=allow_live_tick)
            signal_range = self._clamp_chop_signal_zone(trigger_range, entry_ref)
            distance_metrics = self._entry_distance_metrics(side, entry_ref, int(signal_range["low"]), int(signal_range["high"]))
            range_key = f"CHOP:{side}:{signal_range['low']}:{signal_range['high']}"
            if not self._market_entry_drift_ok(side, entry_ref, int(signal_range["low"]), int(signal_range["high"]), max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD):
                drift_block += 1
                best_blocked = self._update_best_blocked(best_blocked, self._make_blocked_payload(
                    market_state=market_state,
                    side=side,
                    trigger_type="CHOP_MEAN_REVERSION",
                    reason="drift_block",
                    strength=strength,
                    min_strength=min_strength,
                    entry_ref=entry_ref,
                    zone_low=int(signal_range["low"]),
                    zone_high=int(signal_range["high"]),
                    actual_drift_from_zone_edge=float(distance_metrics["entry_vs_zone_edge_distance"]),
                    max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                    bar_time=bar_time,
                    signal_bar_close=bar_metrics["close"],
                    zone_id=range_key,
                ))
                continue

            sl = self._make_chop_sl(side, signal_range)
            tps = self._chop_tp_targets(side, signal_range, entry_ref)
            sig_key = self._signal_signature(side, int(signal_range["low"]), int(signal_range["high"]), sl, tps)
            if not self._duplicate_signal_ok(sig_key, bar_time):
                duplicate_block += 1
                best_blocked = self._update_best_blocked(best_blocked, self._make_blocked_payload(
                    market_state=market_state,
                    side=side,
                    trigger_type="CHOP_MEAN_REVERSION",
                    reason="duplicate_block",
                    strength=strength,
                    min_strength=min_strength,
                    entry_ref=entry_ref,
                    zone_low=int(signal_range["low"]),
                    zone_high=int(signal_range["high"]),
                    actual_drift_from_zone_edge=float(distance_metrics["entry_vs_zone_edge_distance"]),
                    max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                    bar_time=bar_time,
                    signal_bar_close=bar_metrics["close"],
                    zone_id=range_key,
                ))
                continue

            sig = Signal(
                time=bar_time,
                symbol=symbol,
                side=side,
                zone_low=int(signal_range["low"]),
                zone_high=int(signal_range["high"]),
                sl=sl,
                tps=tps,
                regime=market_state.regime,
                entry=entry_ref,
                order_type="MARKET",
                strength=strength,
                bias="NEUTRAL",
                trend_score=market_state.trend_score,
                chop_score=market_state.chop_score,
                overlap_ratio=market_state.overlap_ratio,
                used_min_strength=min_strength,
                used_max_drift=CHOP_MARKET_ENTRY_MAX_DRIFT_USD,
                used_proximity=False,
                trigger_type="CHOP_MEAN_REVERSION",
                be_after_tp1=CHOP_BE_AFTER_TP1,
                atr=market_state.atr,
                htf_ema_fast=market_state.ema_fast,
                htf_ema_slow=market_state.ema_slow,
                trigger_bar_time=bar_time,
                trigger_bar_open=bar_metrics["open"],
                trigger_bar_high=bar_metrics["high"],
                trigger_bar_low=bar_metrics["low"],
                trigger_bar_close=bar_metrics["close"],
                trigger_bar_body_ratio=bar_metrics["body_ratio"],
                trigger_bar_upper_wick_ratio=bar_metrics["upper_wick_ratio"],
                trigger_bar_lower_wick_ratio=bar_metrics["lower_wick_ratio"],
                bars_since_trigger=bars_since_trigger,
                entry_vs_zone_edge_distance=float(distance_metrics["entry_vs_zone_edge_distance"]),
                entry_vs_zone_mid_distance=float(distance_metrics["entry_vs_zone_mid_distance"]),
                chop_range_low=int(trigger_range["low"]),
                chop_range_high=int(trigger_range["high"]),
                chop_range_width=float(trigger_range["width"]),
                chop_containment_ratio=float(trigger_range.get("containment_ratio", 0.0)),
                chop_range_atr_mult=float(trigger_range.get("range_atr_mult", 0.0)),
                zone_id=range_key,
            )
            self.last_signal_time = bar_time
            self.last_bar_index = bar_index
            self.zone_last_fired[range_key] = bar_time
            self.last_no_signal_reason = "signal_found"
            self.signal_signature_last_fired[sig_key] = bar_time
            self.last_scan_reason = (
                f"signal_found(regime={market_state.regime},bias=NEUTRAL,trigger=CHOP_MEAN_REVERSION,"
                f"min_strength={min_strength:.2f},max_drift={CHOP_MARKET_ENTRY_MAX_DRIFT_USD:.2f},"
                f"range_low={sig.chop_range_low},range_high={sig.chop_range_high},range_width={sig.chop_range_width:.2f},"
                f"containment={sig.chop_containment_ratio:.2f},atr_mult={sig.chop_range_atr_mult:.2f})"
            )
            self.last_signal_side = side
            self._emit_signal_found(sig)
            self._save_state()
            self.last_signal_zone_low = int(signal_range["low"])
            self.last_signal_zone_high = int(signal_range["high"])
            return sig

        self.last_no_signal_reason = (
            f"no_chop_signal(reject_block={reject_block},cooldown_block={cooldown_block},reentry_block={reentry_block},"
            f"duplicate_block={duplicate_block},stale_block={stale_block},drift_block={drift_block},"
            f"strength_block={strength_block},lookback={lookback},range_low={last_range_low},range_high={last_range_high},"
            f"range_width={last_range_width:.2f},containment={last_containment_ratio:.2f},atr_mult={last_range_atr_mult:.2f})"
        )
        self.last_scan_reason = self.last_no_signal_reason
        self._emit_signal_blocked(best_blocked)
        return None


    # ---------- MAIN GENERATOR ----------
    def generate_signal(self, symbol: str) -> Optional[Signal]:
        now_utc_dt = datetime.now(timezone.utc)
        if not _is_in_signal_session(now_utc_dt.replace(tzinfo=None)):
            self.last_no_signal_reason = (
                f"out_of_signal_session(now_h={now_utc_dt.hour},start={SIGNAL_SESSION_START_HOUR},"
                f"end={SIGNAL_SESSION_END_HOUR},tz_offset={SIGNAL_SESSION_TZ_OFFSET})"
            )
            self.last_scan_reason = self.last_no_signal_reason
            return None

        df_htf = mt5_rates(symbol, tf_to_mt5(HTF_TF), 600)
        df_tr = mt5_rates(symbol, tf_to_mt5(TRIGGER_TF), 600)
        if df_tr is None or len(df_tr) < 50:
            return None

        lookback = int(clamp(TRIGGER_LOOKBACK_BARS, 1, 30))
        recent = df_tr.iloc[-lookback:]
        last_bar_time = df_tr.index[-1]
        if (not RECHECK_SAME_BAR) and self.last_seen_trigger_bar_time is not None and last_bar_time == self.last_seen_trigger_bar_time:
            self.last_no_signal_reason = "no_new_trigger_bar"
            return None
        self.last_seen_trigger_bar_time = last_bar_time

        market_state = self.classify_market(df_htf)
        if not REGIME_FILTER_ENABLE:
            legacy_state = self._legacy_state(market_state)
            zones = self.compute_zones(df_htf)
            if zones:
                sig = self._generate_zone_signal(
                    symbol, zones, recent, df_tr, lookback, now_utc_dt,
                    legacy_state, self._legacy_signal_params(), allow_live_tick=True,
                )
                if sig is not None:
                    return sig
            return self._generate_chop_signal(
                symbol, [], recent, df_tr, lookback, now_utc_dt, legacy_state, allow_live_tick=True
            )

        if market_state.regime == "TREND":
            zones = self.compute_zones(df_htf)
            if not zones:
                return None
            return self._generate_trend_signal(symbol, zones, recent, df_tr, lookback, now_utc_dt, market_state, allow_live_tick=True)
        if market_state.regime == "CHOP":
            return self._generate_chop_signal(symbol, [], recent, df_tr, lookback, now_utc_dt, market_state, allow_live_tick=True)
        if ALLOW_UNCLEAR_SIGNALS:
            zones = self.compute_zones(df_htf)
            if not zones:
                return None
            return self._generate_zone_signal(symbol, zones, recent, df_tr, lookback, now_utc_dt, market_state,
                                              self._signal_params_for_state(market_state), allow_live_tick=True)

        self.last_no_signal_reason = (
            f"unclear_regime_blocked(bias={market_state.bias},trend_score={market_state.trend_score:.2f},"
            f"chop_score={market_state.chop_score:.2f},overlap={market_state.overlap_ratio:.2f})"
        )
        self.last_scan_reason = self.last_no_signal_reason
        return None


