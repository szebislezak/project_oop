    def _emit_signal_blocked(self, payload: Optional[Dict[str, Any]]) -> None:
        if payload is None:
            return
        global _blocked_log_global_last, _blocked_log_global_count
        signature = f"{payload.get('side')}|{payload.get('reason')}"
        now_dt = now_utc()
        trigger_bar_time = payload.get("trigger_bar_time")
        timed_out = (
            self.last_blocked_log_time is None or
            (now_dt - self.last_blocked_log_time).total_seconds() >= BLOCKED_LOG_COOLDOWN_SECONDS
        )
        if (not timed_out) and signature == self.last_blocked_signature:
            return

        # Globális limit: max BLOCKED_LOG_MAX_PER_MINUTE log percenként
        with _blocked_log_global_lock:
            if _blocked_log_global_last is None or (now_dt - _blocked_log_global_last).total_seconds() >= 60:
                _blocked_log_global_last = now_dt
                _blocked_log_global_count = 0
            if _blocked_log_global_count >= BLOCKED_LOG_MAX_PER_MINUTE:
                return
            _blocked_log_global_count += 1

        self.last_blocked_signature = signature
        self.last_blocked_log_time = now_dt
        self.last_blocked_trigger_bar_time = trigger_bar_time if isinstance(trigger_bar_time, datetime) else self.last_blocked_trigger_bar_time
        self._emit_structured_log("SIGNAL_BLOCKED", payload)

