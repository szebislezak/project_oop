def _test_mt5_connection(login: str, password: str, server: str, path: str = "") -> bool:
    """MT5 kapcsolat tesztelése a user adataival."""
    try:
        if path and os.path.exists(path):
            ok = mt5.initialize(path=path, login=int(login), password=password, server=server)
        else:
            ok = mt5.initialize(login=int(login), password=password, server=server)
        mt5.shutdown()
        return ok
    except Exception:
        return False


def _get_user_mt5_path(user: dict) -> str:
    """Visszaadja a user MT5 portable exe elérési útját."""
    # Ha már be van állítva a usernek
    if user.get("mt5_path") and os.path.exists(user["mt5_path"]):
        return user["mt5_path"]
    # Generálunk egy várható path-ot login alapján
    login = user.get("login", "unknown")
    expected = os.path.join(MT5_INSTANCES_DIR, f"instance_{login}", "terminal64.exe")
    if os.path.exists(expected):
        return expected
    return ""


def _create_mt5_config(user: dict, include_password: bool = False) -> str:
    """
    Létrehozza a MT5 config fájlt a portable instance-hoz.
    include_password=True → jelszót is beírja (autologin)
    Visszaadja az instance mappáját.
    """
    login    = user.get("login", "")
    server   = user.get("server", "")
    password = user.get("password", "") if include_password else ""
    instance_dir = os.path.join(MT5_INSTANCES_DIR, f"instance_{login}")
    config_dir   = os.path.join(instance_dir, "config")
    os.makedirs(config_dir, exist_ok=True)

    # common.ini - MT5 autologin config (jelszóval együtt ha kérték)
    config_path = os.path.join(config_dir, "common.ini")
    config_lines = [
        "[Common]",
        f"Login={login}",
        f"Server={server}",
        "ProxyType=0",
        "EnableNews=0",
        "[StartUp]",
        "Expert=",
    ]
    if include_password and password:
        # Jelszó beírása — MT5 ezt elfogadja autologinhoz
        config_lines.insert(3, f"Password={password}")

    config_content = "\n".join(config_lines) + "\n"
    with open(config_path, "w", encoding="utf-8") as f:
        f.write(config_content)

    print(f"[MULTIUSER] Config created: {config_path} (password={'yes' if include_password and password else 'no'})")
    return instance_dir


def _create_mt5_config(user: dict, include_password: bool = False) -> str:
    """Config fájl létrehozása jelszóval együtt ha kérték."""
    login    = user.get("login", "")
    server   = user.get("server", "")
    password = user.get("password", "") if include_password else ""
    instance_dir = os.path.join(MT5_INSTANCES_DIR, f"instance_{login}")
    config_dir   = os.path.join(instance_dir, "config")
    os.makedirs(config_dir, exist_ok=True)
    config_path = os.path.join(config_dir, "common.ini")
    lines = ["[Common]", f"Login={login}", f"Server={server}",
             "ProxyType=0", "EnableNews=0", "[StartUp]", "Expert="]
    if include_password and password:
        lines.insert(3, f"Password={password}")
    with open(config_path, "w", encoding="utf-8") as f:
        f.write("\n".join(lines) + "\n")
    print(f"[MULTIUSER] Config: {config_path} pw={'yes' if include_password and password else 'no'}")
    return instance_dir


def _launch_mt5_instance(user: dict) -> bool:
    """MT5 instance elindítása jelszóval parancssorból."""
    import subprocess
    login    = user.get("login", "")
    password = user.get("password", "")
    server   = user.get("server", "")
    mt5_exe  = os.path.join(MT5_INSTANCES_DIR, f"instance_{login}", "terminal64.exe")

    if not os.path.exists(mt5_exe):
        print(f"[MULTIUSER] MT5 exe not found: {mt5_exe}")
        return False
    try:
        # Próbáljuk parancssorból átadni a jelszót
        # MT5 5715+ build támogatja a /login /password /server argumentumokat
        cmd = [mt5_exe,
               f"/login:{login}",
               f"/password:{password}",
               f"/server:{server}",
               "/portable"]
        subprocess.Popen(cmd, cwd=os.path.dirname(mt5_exe))
        print(f"[MULTIUSER] MT5 launched with credentials: {mt5_exe}")
        return True
    except Exception as e:
        print(f"[MULTIUSER] Launch error: {e}")
        return False

def _send_user_status(chat_id: str) -> None:
    """Felhasználó saját pozícióinak kiküldése."""
    user = _load_user(chat_id)
    if not user:
        _send_to(chat_id, "ℹ️ Nincs regisztrált adatod. Írd: /start")
        return
    try:
        ok = mt5.initialize(login=int(user["login"]), password=user["password"], server=user["server"])
        if not ok:
            _send_to(chat_id, "❌ MT5 kapcsolat sikertelen a státusz lekéréséhez.")
            return
        positions = mt5.positions_get(symbol=SYMBOL)
        positions = [p for p in (positions or []) if p.magic == AUTOTRADE_MAGIC]
        active_str = "▶️ AKTÍV" if user.get("active", True) else "⏸ SZÜNET"
        if not positions:
            _send_to(chat_id, f"📊 Autotrade: {active_str}\nNincs nyitott pozíció.")
            return
        total_pnl = sum(p.profit for p in positions)
        pnl_str = f"+${total_pnl:.2f}" if total_pnl >= 0 else f"-${abs(total_pnl):.2f}"
        lines = [f"📊 {active_str} | {len(positions)} pozíció | P&L: {pnl_str}"]
        for p in positions:
            side_str = "BUY" if p.type == 0 else "SELL"
            p_str = f"+${p.profit:.2f}" if p.profit >= 0 else f"-${abs(p.profit):.2f}"
            lines.append(f"#{p.ticket} {side_str} @ {p.price_open:.2f} | {p_str}")
        _send_to(chat_id, "\n".join(lines))
    finally:
        mt5.shutdown()


def _privat_send(text: str) -> None:
    """Üzenet küldése csak a PRIVÁT autotrade chat-be."""
    if not TELEGRAM_BOT_TOKEN or not AUTOTRADE_CHAT_ID:
        return
    url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"
    try:
        requests.post(url, json={
            "chat_id": AUTOTRADE_CHAT_ID,
            "text": text,
            "disable_web_page_preview": True
        }, timeout=10)
    except Exception as e:
        print(f"[AUTOTRADE] Telegram send error: {e}")


def _at_mt5_connect() -> bool:
    """MT5 connect autotrade céljára (login ha van konfig)."""
    if MT5_LOGIN and MT5_PASSWORD and MT5_SERVER:
        ok = mt5.initialize(login=MT5_LOGIN, password=MT5_PASSWORD, server=MT5_SERVER)
    else:
        ok = mt5.initialize()
    if not ok:
        print(f"[AUTOTRADE] MT5 init failed: {mt5.last_error()}")
    return ok


def _at_open_positions() -> list:
    positions = mt5.positions_get(symbol=SYMBOL)
    if positions is None:
        return []
    return [p for p in positions if p.magic == AUTOTRADE_MAGIC]


def _at_close_all() -> None:
    if not _at_mt5_connect():
        _privat_send("❌ MT5 kapcsolat sikertelen záráshoz!")
        return
    try:
        positions = _at_open_positions()
        if not positions:
            _privat_send("ℹ️ Nincs nyitott pozíció.")
            return
        closed = 0
        for pos in positions:
            close_type = mt5.ORDER_TYPE_SELL if pos.type == 0 else mt5.ORDER_TYPE_BUY
            tick  = mt5.symbol_info_tick(SYMBOL)
            price = tick.bid if pos.type == 0 else tick.ask
            req = {
                "action": mt5.TRADE_ACTION_DEAL, "symbol": SYMBOL,
                "volume": pos.volume, "type": close_type,
                "position": pos.ticket, "price": price,
                "deviation": 30, "magic": AUTOTRADE_MAGIC,
                "comment": "manual_close", "type_time": mt5.ORDER_TIME_GTC,
                "type_filling": mt5.ORDER_FILLING_IOC,
            }
            r = mt5.order_send(req)
            if r and r.retcode == mt5.TRADE_RETCODE_DONE:
                closed += 1
        _privat_send(f"✅ {closed}/{len(positions)} pozíció zárva!")
    finally:
        mt5.shutdown()


def _at_send_status() -> None:
    if not _at_mt5_connect():
        _privat_send("❌ MT5 kapcsolat sikertelen!")
        return
    try:
        positions = _at_open_positions()
        with _autotrade_lock:
            active = _autotrade_active
        status_str = "▶️ AKTÍV" if active else "⏸ SZÜNET"
        if not positions:
            _privat_send(f"📊 Autotrade: {status_str}\nNincs nyitott pozíció.")
            return
        total_pnl = sum(p.profit for p in positions)
        pnl_str = f"+${total_pnl:.2f}" if total_pnl >= 0 else f"-${abs(total_pnl):.2f}"
        lines = [f"📊 Autotrade: {status_str} | {len(positions)} pozíció | P&L: {pnl_str}\n"]
        for p in positions:
            side_str = "BUY" if p.type == 0 else "SELL"
            p_str = f"+${p.profit:.2f}" if p.profit >= 0 else f"-${abs(p.profit):.2f}"
            lines.append(f"#{p.ticket} {side_str} @ {p.price_open:.2f} → {p.price_current:.2f} | {p_str}")
        _privat_send("\n".join(lines))
    finally:
        mt5.shutdown()


