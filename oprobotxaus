def _execute_for_user(user: dict, sig) -> None:
    """Egy user számláján nyit pozíciókat."""
    chat_id = user.get("chat_id", "")
    login   = user.get("login")
    password = user.get("password")
    server  = user.get("server")
    lot     = float(user.get("lot", 0.05))

    side = sig.side.upper()
    sl   = float(sig.sl)
    real_tps = [float(t) for t in sig.tps if t is not None]
    tp1  = real_tps[0] if len(real_tps) > 0 else None
    tp2  = real_tps[1] if len(real_tps) > 1 else None

    if tp1 is None:
        return

    # Csak aktivált usereknek nyit
    if not user.get("mt5_ready", False):
        print(f"[MULTIUSER] User {chat_id} not ready yet, skipping")
        return

    try:
        mt5_path = _get_user_mt5_path(user)
        if mt5_path:
            ok = mt5.initialize(path=mt5_path, login=int(login), password=password, server=server)
        else:
            ok = mt5.initialize(login=int(login), password=password, server=server)
        if not ok:
            _send_to(chat_id, f"❌ MT5 kapcsolat sikertelen! Ellenőrizd adataidat: /start")
            return

        tick = mt5.symbol_info_tick(SYMBOL)
        if tick is None:
            return
        price   = tick.ask if side == "BUY" else tick.bid
        order_t = mt5.ORDER_TYPE_BUY if side == "BUY" else mt5.ORDER_TYPE_SELL

        import threading as _th
        tp1_hit_event = _th.Event()
        opened = []
        errors = []

        # User max pozíció beállítása (alapértelmezett: 3)
        max_positions = int(user.get("max_positions", 3))
        # Admin esetén a globális ADMIN_MAX_POSITIONS-t használjuk
        all_positions = [
            ("MM_TP1", tp1, False),
            ("MM_TP2", tp2 if tp2 else tp1, sig.be_after_tp1),
            ("MM_HOLD", 0.0, sig.be_after_tp1),
        ]
        positions_to_open = all_positions[:max_positions]

        for label, tp_val, be_flag in positions_to_open:
            r = mt5.order_send({
                "action": mt5.TRADE_ACTION_DEAL, "symbol": SYMBOL,
                "volume": lot, "type": order_t, "price": price,
                "sl": sl, "tp": tp_val if tp_val else 0.0,
                "deviation": 30, "magic": AUTOTRADE_MAGIC,
                "comment": label, "type_time": mt5.ORDER_TIME_GTC,
                "type_filling": mt5.ORDER_FILLING_IOC,
            })
            if r and r.retcode == mt5.TRADE_RETCODE_DONE:
                opened.append((label, r.order))
                ev = tp1_hit_event if label != "MM_TP1" else None
                tp1_ev = tp1_hit_event if label == "MM_TP1" else None
                _th.Thread(
                    target=_at_position_monitor_for_user,
                    args=(r.order, side, r.price, sl, tp1, tp2, None, be_flag, tp1_hit_event, login, password, server, chat_id),
                    daemon=True
                ).start()
            else:
                errors.append(label)

        tp2_s = int(tp2) if tp2 else "–"
        be_s = "\n🔁 TP1 után: BE" if sig.be_after_tp1 else ""
        msg_lines = [
            f"✅ {len(opened)}/{max_positions} pozíció nyitva: {side} @ {price:.2f}",
            f"   SL: {int(sl)} | TP1: {int(tp1)} | TP2: {tp2_s} | TP3: HOLD{be_s}",
        ]
        for label, ticket in opened:
            msg_lines.append(f"   #{ticket} → {label.replace('MM_', '')}")
        if errors:
            msg_lines.append(f"⚠️ Nem nyílt: {', '.join(errors)}")
        _send_to(chat_id, "\n".join(msg_lines))

    except Exception as e:
        print(f"[MULTIUSER] Error for user {chat_id}: {e}")
        _send_to(chat_id, f"❌ Hiba a pozíció nyitásnál: {e}")
    finally:
        mt5.shutdown()


def _at_position_monitor_for_user(ticket, side, entry, sl, tp1, tp2, tp3, be_flag, tp1_hit_event, login, password, server, chat_id):
    """Pozíció figyelő user számlájához - saját MT5 kapcsolattal."""
    import threading as _th
    be_done = False
    tp2_done = False
    while True:
        time.sleep(3)
        try:
            ok = mt5.initialize(login=int(login), password=password, server=server)
            if not ok:
                time.sleep(10)
                continue
            positions = mt5.positions_get(ticket=ticket)
            if not positions:
                history = mt5.history_deals_get(position=ticket)
                if history:
                    profit = sum(d.profit for d in history)
                    pnl_str = f"+${profit:.2f}" if profit >= 0 else f"-${abs(profit):.2f}"
                    _send_to(chat_id, f"🏁 Pozíció zárva | #{ticket} | P&L: {pnl_str}")
                    if tp1_hit_event and not tp1_hit_event.is_set():
                        tp1_hit_event.set()
                break
            pos = positions[0]
            tick = mt5.symbol_info_tick(SYMBOL)
            if tick is None:
                continue
            cur = tick.ask if side == "BUY" else tick.bid

            tp1_reached = False
            if tp1 is not None:
                tp1_reached = (side == "BUY" and cur >= tp1) or (side == "SELL" and cur <= tp1)
            if tp1_hit_event and tp1_hit_event.is_set():
                tp1_reached = True

            if be_flag and not be_done and tp1_reached:
                be_price = round(entry + 0.30, 2) if side == "BUY" else round(entry - 0.30, 2)
                r = mt5.order_send({
                    "action": mt5.TRADE_ACTION_SLTP, "symbol": SYMBOL,
                    "position": ticket, "sl": be_price, "tp": pos.tp,
                })
                if r and r.retcode == mt5.TRADE_RETCODE_DONE:
                    be_done = True
                    _send_to(chat_id, f"🔁 SL BE+spread: {be_price:.2f} | #{ticket}")
                    if tp1_hit_event and not tp1_hit_event.is_set():
                        tp1_hit_event.set()
        except Exception as e:
            print(f"[MULTIUSER] Monitor error for {chat_id}: {e}")
        finally:
            mt5.shutdown()


def _at_telegram_poll_loop() -> None:
    """Háttér szál: minden üzenet figyelése (admin + felhasználók)."""
    global _at_last_update_id
    print("[AUTOTRADE] Command listener started (multi-user mode)")
    while True:
        try:
            url    = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/getUpdates"
            params = {"timeout": 0, "offset": _at_last_update_id + 1}
            resp   = requests.get(url, params=params, timeout=10)
            data   = resp.json()
            if not data.get("ok"):
                time.sleep(5)
                continue
            for update in data.get("result", []):
                _at_last_update_id = update["update_id"]
                msg = update.get("message") or update.get("channel_post")
                if not msg:
                    continue
                chat_id = str(msg.get("chat", {}).get("id", ""))
                text = msg.get("text", "")
                if not text:
                    continue

                # Jelzőcsoport(ok) üzeneteit FIGYELMEN KÍVÜL HAGYJUK
                signal_chat_ids = [c.strip() for c in TELEGRAM_CHAT_IDS.split(",") if c.strip()]
                if chat_id in signal_chat_ids:
                    continue

                # Log - jelszó lépésnél nem írjuk ki a szöveget!
                with _reg_lock:
                    current_step = _reg_state.get(chat_id, {}).get("step", "")
                if current_step == "password":
                    print(f"[AUTOTRADE] Msg from {chat_id}: [JELSZÓ - ELREJTVE]")
                elif text.startswith("/"):
                    print(f"[AUTOTRADE] Msg from {chat_id}: {text[:30]}")
                else:
                    print(f"[AUTOTRADE] Msg from {chat_id}: [adat - elrejtve]")
                # Parancs feldolgozása külön szálban hogy ne blokkolja a poll loopot
                import threading as _th
                _th.Thread(
                    target=_handle_user_command,
                    args=(chat_id, text),
                    daemon=True
                ).start()
        except Exception as e:
            print(f"[AUTOTRADE] Poll error: {e}")
            time.sleep(5)


