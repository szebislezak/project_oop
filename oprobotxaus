def _at_position_monitor(ticket, side, entry, sl, tp1, tp2, tp3, be_flag, tp1_hit_event=None):
    """
    Háttér szál: BE húzás + pozíció zárás figyelés.
    be_flag=True → BE húzás ha:
      1. Az ár eléri tp1-et
      2. VAGY tp1_hit_event kisül
      3. VAGY a TP1 pozíció eltűnt az MT5-ből (magic alapján keresve)
    """
    import threading as _th
    be_done = False
    tp2_done = False
    print(f"[AUTOTRADE] Monitor started for ticket={ticket} be_flag={be_flag}")
    while True:
        time.sleep(2)
        if not _at_mt5_connect():
            time.sleep(10)
            continue
        try:
            positions = mt5.positions_get(ticket=ticket)
            # Pozíció zárult
            if not positions:
                history = mt5.history_deals_get(position=ticket)
                if history:
                    profit = sum(d.profit for d in history)
                    pnl_str = f"+${profit:.2f}" if profit >= 0 else f"-${abs(profit):.2f}"
                    _privat_send(f"🏁 Pozíció zárva | Ticket: #{ticket} | P&L: {pnl_str}")
                    if tp1_hit_event is not None and not tp1_hit_event.is_set():
                        tp1_hit_event.set()
                break

            pos = positions[0]
            tick = mt5.symbol_info_tick(SYMBOL)
            if tick is None:
                continue
            cur = tick.ask if side == "BUY" else tick.bid

            # TP1 elérve - háromféleképpen ellenőrzünk:
            tp1_reached = False

            # 1. Ár alapján
            if tp1 is not None:
                tp1_reached = (side == "BUY" and cur >= tp1) or (side == "SELL" and cur <= tp1)

            # 2. Event alapján (TP1 pozíció zárult)
            if not tp1_reached and tp1_hit_event is not None and tp1_hit_event.is_set():
                tp1_reached = True

            # 3. MM_TP1 kommentű pozíció eltűnt-e az MT5-ből (legmegbízhatóbb módszer)
            if not tp1_reached and be_flag:
                all_positions = mt5.positions_get(symbol=SYMBOL)
                if all_positions is not None:
                    tp1_tickets = [p.ticket for p in all_positions
                                   if p.magic == AUTOTRADE_MAGIC and p.comment == "MM_TP1"]
                    # Ha nincs MM_TP1 pozíció → TP1 már zárult
                    # Ez a HOLD pozícióra is vonatkozik (TP2 már zárulhatott mire ellenőriz)
                    if not tp1_tickets:
                        tp1_reached = True
                        if tp1_hit_event is not None and not tp1_hit_event.is_set():
                            tp1_hit_event.set()
                        print(f"[AUTOTRADE] TP1 detected closed via position scan for #{ticket}")

            # BE húzás (+0.30 spread buffer)
            if be_flag and not be_done and tp1_reached:
                be_price = round(entry + 0.30, 2) if side == "BUY" else round(entry - 0.30, 2)
                for attempt in range(3):
                    r = mt5.order_send({
                        "action": mt5.TRADE_ACTION_SLTP, "symbol": SYMBOL,
                        "position": ticket, "sl": be_price, "tp": pos.tp,
                    })
                    if r and r.retcode == mt5.TRADE_RETCODE_DONE:
                        be_done = True
                        _privat_send(f"🔁 TP1 elérve → SL BE+spread: {be_price:.2f}\n   Ticket: #{ticket}")
                        if tp1_hit_event is not None and not tp1_hit_event.is_set():
                            tp1_hit_event.set()
                        break
                    else:
                        err = r.comment if r else "None"
                        print(f"[AUTOTRADE] BE set failed (attempt {attempt+1}): {err}")
                        time.sleep(1)

            # TP2 elérve → TP3 (ha van)
            if be_done and not tp2_done and tp2 is not None and tp3 is not None:
                tp2_hit = (side == "BUY" and cur >= tp2) or (side == "SELL" and cur <= tp2)
                if tp2_hit:
                    r = mt5.order_send({
                        "action": mt5.TRADE_ACTION_SLTP, "symbol": SYMBOL,
                        "position": ticket, "sl": pos.sl, "tp": tp3,
                    })
                    if r and r.retcode == mt5.TRADE_RETCODE_DONE:
                        tp2_done = True
                        _privat_send(f"🎯 TP2 elérve → TP3-ra állítva: {int(tp3)}\n   Ticket: #{ticket}")
        except Exception as e:
            print(f"[AUTOTRADE] Monitor error: {e}")
        finally:
            mt5.shutdown()


WORKER_SIGNAL_FILE = "worker_signal.json"

def _write_signal_for_workers(sig) -> None:
    """Signal adatokat fájlba írja a worker.py processek számára."""
    try:
        data = {
            "time": now_utc().isoformat(),
            "side": sig.side,
            "sl": sig.sl,
            "tps": [t for t in sig.tps],
            "be_after_tp1": sig.be_after_tp1,
            "symbol": SYMBOL,
        }
        with open(WORKER_SIGNAL_FILE, "w", encoding="utf-8") as f:
            json.dump(data, f)
        print(f"[WORKER] Signal written to {WORKER_SIGNAL_FILE}")
    except Exception as e:
        print(f"[WORKER] Write error: {e}")


def execute_autotrade(sig) -> None:
    """
    1 signal → 3 pozíció nyílik:
      Poz 1: TP1 célra
      Poz 2: TP2 célra
      Poz 3: HOLD (nincs TP, fut tovább)
    """
    global _autotrade_active
    if not AUTOTRADE_ENABLE:
        return
    with _autotrade_lock:
        active = _autotrade_active
    if not active:
        print("[AUTOTRADE] Paused – signal skipped")
        return

    side = sig.side.upper()

    # Autotrade side toggle ellenőrzés
    with _toggle_lock:
        at_buy_ok  = _autobuy_enabled
        at_sell_ok = _autosell_enabled
    if side == "BUY" and not at_buy_ok:
        print(f"[TOGGLE] Autotrade BUY blokkolva (autobuy_disabled)")
        return
    if side == "SELL" and not at_sell_ok:
        print(f"[TOGGLE] Autotrade SELL blokkolva (autosell_disabled)")
        return

    sl   = float(sig.sl)
    real_tps = [float(t) for t in sig.tps if t is not None]
    tp1  = real_tps[0] if len(real_tps) > 0 else None
    tp2  = real_tps[1] if len(real_tps) > 1 else None
    # TP3 = HOLD → nincs TP beállítva MT5-ön

    if tp1 is None:
        _privat_send("⚠️ Autotrade: nincs TP1 – pozíciók NEM nyíltak")
        return
    if not _at_mt5_connect():
        _privat_send("❌ Autotrade: MT5 kapcsolat sikertelen!")
        return

    try:
        tick = mt5.symbol_info_tick(SYMBOL)
        if tick is None:
            _privat_send(f"❌ Autotrade: nem kaptam árat ({SYMBOL})")
            return
        price   = tick.ask if side == "BUY" else tick.bid
        order_t = mt5.ORDER_TYPE_BUY if side == "BUY" else mt5.ORDER_TYPE_SELL

        import threading as _th

        opened = []
        errors = []

        # Admin max pozíció (setpositions paranccsal állítható)
        admin_max = globals().get("ADMIN_MAX_POSITIONS", 3)

        # Közös event: ha TP1 zárult, TP2 és HOLD is BE-re húzódik
        tp1_hit_event = _th.Event()

        # --- Pozíció 1: TP1 célra ---
        r1 = mt5.order_send({
            "action": mt5.TRADE_ACTION_DEAL, "symbol": SYMBOL,
