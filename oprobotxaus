def _get_fernet() -> "Fernet":
    """Titkosítási kulcs - az .env-ből vagy generál egyet."""
    key_file = os.path.join(USERS_DIR, ".key")
    if os.path.exists(key_file):
        with open(key_file, "rb") as f:
            key = f.read().strip()
    else:
        key = Fernet.generate_key()
        with open(key_file, "wb") as f:
            f.write(key)
        print(f"[MULTIUSER] Új titkosítási kulcs generálva: {key_file}")
    return Fernet(key)

def _user_file(chat_id: str) -> str:
    h = hashlib.sha256(str(chat_id).encode()).hexdigest()[:16]
    return os.path.join(USERS_DIR, f"u_{h}.enc")

def _save_user(chat_id: str, data: dict) -> None:
    if not CRYPTO_AVAILABLE:
        return
    f = _get_fernet()
    raw = json.dumps(data).encode()
    encrypted = f.encrypt(raw)
    with open(_user_file(chat_id), "wb") as fp:
        fp.write(encrypted)

def _load_user(chat_id: str) -> Optional[dict]:
    path = _user_file(chat_id)
    if not os.path.exists(path):
        return None
    if not CRYPTO_AVAILABLE:
        return None
    try:
        f = _get_fernet()
        with open(path, "rb") as fp:
            encrypted = fp.read()
        raw = f.decrypt(encrypted)
        return json.loads(raw.decode())
    except Exception as e:
        print(f"[MULTIUSER] Load user error: {e}")
        return None

def _delete_user(chat_id: str) -> bool:
    path = _user_file(chat_id)
    if os.path.exists(path):
        os.remove(path)
        return True
    return False

def _list_users() -> List[dict]:
    """Visszaadja az összes user adatát (admin használja)."""
    users = []
    if not CRYPTO_AVAILABLE:
        return users
    f = _get_fernet()
    for fname in os.listdir(USERS_DIR):
        if not fname.endswith(".enc"):
            continue
        try:
            with open(os.path.join(USERS_DIR, fname), "rb") as fp:
                encrypted = fp.read()
            raw = f.decrypt(encrypted)
            users.append(json.loads(raw.decode()))
        except Exception:
            pass
    return users

