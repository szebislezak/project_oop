            "sl": sl, "tp": tp1, "deviation": 30, "magic": AUTOTRADE_MAGIC,
            "comment": "MM_TP1", "type_time": mt5.ORDER_TIME_GTC,
            "type_filling": mt5.ORDER_FILLING_IOC,
        })
        if r1 and r1.retcode == mt5.TRADE_RETCODE_DONE:
            opened.append(("TP1", r1.order, r1.price, tp1))
            _th.Thread(target=_at_position_monitor,
                args=(r1.order, side, r1.price, sl, tp1, None, None, False, tp1_hit_event),
                daemon=True).start()
        else:
            errors.append(f"Poz1(TP1): {r1.comment if r1 else 'None'}")
            tp1_hit_event.set()

        # --- Pozíció 2: TP2 célra (csak ha admin_max >= 2) ---
